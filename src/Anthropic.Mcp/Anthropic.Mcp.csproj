<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <RootNamespace>Anthropic.Helpers.Beta.Mcp</RootNamespace>
    <AssemblyName>Anthropic.Mcp</AssemblyName>
    <PackageId>Anthropic.Mcp</PackageId>
    <VersionPrefix>0.1.0</VersionPrefix>
    <AssemblyTitle>Anthropic MCP Helpers</AssemblyTitle>
    <Description>Helpers for using Model Context Protocol (MCP) servers with the Anthropic .NET SDK.</Description>
    <PackageIcon>logo.png</PackageIcon>
  </PropertyGroup>
  <ItemGroup>
    <None Include="..\logo.png" Pack="true" PackagePath="\" />
    <InternalsVisibleTo Include="Anthropic.Tests,"/>
    <ProjectReference Include="..\Anthropic\Anthropic.csproj" />
    <PackageReference Include="ModelContextProtocol.Core" Version="1.2.0" />
  </ItemGroup>
  <ItemGroup Condition="'$(TargetFramework)' == 'netstandard2.0'">
    <PackageReference Include="System.Memory" Version="4.6.3" />
    <PackageReference Include="System.Threading.Tasks.Extensions" Version="4.6.3" />
  </ItemGroup>
</Project>
